app.use((req, res, next) => {
  const start = Date.now();
  const path = req.path;
  let capturedJsonResponse: Record<string, any> | undefined = undefined;

  const originalResJson = res.json;
  res.json = function (bodyJson, ...args) {
    capturedJsonResponse = bodyJson;
    return originalResJson.apply(res, [bodyJson, ...args]);
  };

  res.on("finish", () => {
    const duration = Date.now() - start;
    if (path.startsWith("/api")) {
      let logLine = `${req.method} ${path} ${res.statusCode} in ${duration}ms`;
      if (capturedJsonResponse) {
        logLine += ` :: ${JSON.stringify(capturedJsonResponse)}`;
      }

      log(logLine);
    }
  });

  next();
});

(async () => {
  await registerRoutes(httpServer, app);

  app.use((err: any, _req: Request, res: Response, next: NextFunction) => {
    const status = err.status || err.statusCode || 500;
    const message = err.message || "Internal Server Error";

    console.error("Internal Server Error:", err);

    if (res.headersSent) {
      return next(err);
    }

    return res.status(status).json({ message });
  });

  // importantly only setup vite in development and after
  // setting up all the other routes so the catch-all route
  // doesn't interfere with the other routes
  if (process.env.NODE_ENV === "production") {
    serveStatic(app);
  } else {
    const { setupVite } = await import("./vite");
    await setupVite(httpServer, app);
  }

  // ALWAYS serve the app on the port specified in the environment variable PORT
  // Other ports are firewalled. Default to 5000 if not specified.
  // this serves both the API and the client.
  // It is the only port that is not firewalled.
  const port = parseInt(process.env.PORT || "5000", 10);
  httpServer.listen(
    {
      port,
      host: "0.0.0.0",
      reusePort: true,
    },
    () => {
      log(`serving on port ${port}`);
    },
  );
})();


import type { Express } from "express";
import type { Server } from "http";
import multer from "multer";
import path from "path";
import fs from "fs";
import { spawn } from "child_process";
import { storage } from "./storage";
import { api } from "@shared/routes";
import type { DetectorResult } from "@shared/schema";

const upload = multer({
  dest: "uploads/",
  limits: { fileSize: 50 * 1024 * 1024 },
});

export async function registerRoutes(
  httpServer: Server,
  app: Express
): Promise<Server> {
  
  if (!fs.existsSync("uploads")) {
    fs.mkdirSync("uploads");
  }

  app.post(api.analyze.upload.path, upload.single("file"), async (req, res) => {
    if (!req.file) {
      return res.status(400).json({ message: "No file uploaded" });
    }

    const filePath = req.file.path;
    const originalName = req.file.originalname;
    const fileExtension = path.extname(originalName).toLowerCase();
    
    const supportedAudio = ['.wav', '.mp3', '.m4a', '.aac', '.ogg', '.flac', '.wma', '.opus'];
    const supportedVideo = ['.mp4', '.mov', '.mkv', '.webm', '.avi'];
    const allSupported = [...supportedAudio, ...supportedVideo];
    
    if (!allSupported.includes(fileExtension)) {
      fs.unlink(filePath, () => {});
      return res.status(400).json({ 
        message: `Unsupported file format: ${fileExtension}`,
        details: `Supported formats: ${allSupported.join(', ')}`
      });
    }
    
    const stats = fs.statSync(filePath);
    if (stats.size > 50 * 1024 * 1024) {
      fs.unlink(filePath, () => {});
      return res.status(400).json({ 
        message: "File too large",
        details: "Maximum file size is 50MB"
      });
    }

    const mode = (req.body?.mode === "fast") ? "fast" : "research";
    console.log(`Analyzing file: ${originalName} (${stats.size} bytes, mode: ${mode})`);

    const filePathWithExt = filePath + fileExtension;
    try {
      fs.renameSync(filePath, filePathWithExt);
    } catch (e) {
      console.error("Error renaming file:", e);
      fs.unlink(filePath, () => {});
      return res.status(500).json({ message: "Failed to prepare file for analysis" });
    }

    const pythonProcess = spawn("python3", [
      "detect.py", "--input", filePathWithExt, "--mode", mode, "--json"
    ]);

    let outputData = "";
    let errorData = "";

    pythonProcess.stdout.on("data", (data) => {
      outputData += data.toString();
    });

    pythonProcess.stderr.on("data", (data) => {
      errorData += data.toString();
      console.error("Python stderr:", data.toString());
    });

    pythonProcess.on("close", async (code) => {
      fs.unlink(filePathWithExt, (err) => {
        if (err) console.error("Error deleting file:", err);
      });

      if (code !== 0) {
        console.error(`Python script exited with code ${code}`);
        console.error(`Stderr: ${errorData}`);
        const errorMessage = errorData.trim() || "Unknown error during analysis";
        return res.status(500).json({ 
          message: "Analysis failed", 
          details: errorMessage 
        });
      }

      try {
        const result = JSON.parse(outputData);
        
        const detectorResults: DetectorResult[] = result.detectors || [];
        
        // Handle final_verdict as either a flat string or an object {verdict, confidence, reason}
        let finalVerdict: string;
        let finalConfidence: number;
        let finalReason: string;
        if (typeof result.final_verdict === "object" && result.final_verdict !== null) {
          finalVerdict = result.final_verdict.verdict || "Unknown";
          finalConfidence = result.final_verdict.confidence ?? 50;
          finalReason = result.final_verdict.reason || "";
        } else {
          finalVerdict = result.final_verdict || "Unknown";
          finalConfidence = result.final_confidence || 50;
          finalReason = result.final_reason || "";
        }
        
        // isDeepfake is true only when final verdict is "AI"
        const isDeepfake = finalVerdict === "AI";
        
        // Handle explanation as either string or array
        const allExplanations = detectorResults
          .filter(d => d.available)
          .flatMap(d => {
            const expl = d.explanation;
            if (Array.isArray(expl)) {
              return expl.slice(0, 2).map((e: string) => `[${d.model_name}] ${e}`);
            }
            if (typeof expl === "string" && expl) {
              return [`[${d.model_name}] ${expl}`];
            }
            return [];
          })
          .slice(0, 5);

        // Handle language/gender
        const language = result.language
          ? `${result.language} (${(result.lang_confidence ?? 0).toFixed(2)})`
          : "Unknown";
        const genderLabel = result.gender || "Uncertain";
        const genderConf = result.gender_confidence ?? 0;
        const gender = `${genderLabel} (${genderConf.toFixed(2)})`;

        const analysis = await storage.createAnalysis({
          fileName: originalName,
          fileType: fileExtension,
          mode: result.mode || "research",
          detectorResults: detectorResults,
          isDeepfake,
          confidence: finalConfidence / 100,
          language,
          gender,
          duration: result.duration || 0,
          sampleRate: result.sample_rate || "16kHz",
          explanation: allExplanations,
          rawOutput: outputData,
          finalVerdict: {
            verdict: finalVerdict,
            confidence: finalConfidence,
            reason: finalReason,
          },
          compressionNotes: result.compression_notes || [],
        });

        res.json(analysis);

      } catch (err) {
        console.error("Error parsing JSON output:", err);
        console.error("Raw output:", outputData);
        res.status(500).json({ message: "Failed to parse analysis results" });
      }
    });
  });

  app.get(api.history.list.path, async (req, res) => {
    const history = await storage.getAnalyses();
    res.json(history);
  });

  return httpServer;
}

import express, { type Express } from "express";
import fs from "fs";
import path from "path";

export function serveStatic(app: Express) {
  const distPath = path.resolve(__dirname, "public");
  if (!fs.existsSync(distPath)) {
    throw new Error(
      `Could not find the build directory: ${distPath}, make sure to build the client first`,
    );
  }

  app.use(express.static(distPath));

  // fall through to index.html if the file doesn't exist
  app.use("/{*path}", (_req, res) => {
    res.sendFile(path.resolve(distPath, "index.html"));
  });
}


import { analyses, type InsertAnalysis, type Analysis } from "@shared/schema";
