"""
LFCC + GMM Baseline for Audio Deepfake Detection
================================================
This is a CPU-friendly implementation based on the ASVspoof 2019 baseline.

References:
- Todisco et al., "ASVspoof 2019: Automatic Speaker Verification Spoofing 
  and Countermeasures Challenge", INTERSPEECH 2019
- Baseline EER: ~5.06% on ASVspoof 2019 LA

The LFCC (Linear Frequency Cepstral Coefficients) features are similar to MFCC
but use a linear filterbank instead of mel scale, which better captures 
artifacts from vocoders and TTS systems.
"""

import numpy as np
import librosa
from scipy.fftpack import dct


def extract_lfcc(y, sr=16000, n_lfcc=20, n_fft=512, hop_length=160, n_filters=20):
    """
    Extract Linear Frequency Cepstral Coefficients (LFCC).
    
    Args:
        y: Audio signal (mono, 16kHz)
        sr: Sample rate
        n_lfcc: Number of cepstral coefficients to return
        n_fft: FFT window size
        hop_length: Hop length for STFT
        n_filters: Number of linear filters
        
    Returns:
        lfcc: LFCC feature matrix (n_lfcc x n_frames)
    """
    # Compute STFT magnitude spectrum
    S = np.abs(librosa.stft(y, n_fft=n_fft, hop_length=hop_length))
    
    # Create linear filterbank (instead of mel)
    # Linear spacing from 0 to Nyquist
    fmin, fmax = 0, sr // 2
    filterbank = librosa.filters.mel(sr=sr, n_fft=n_fft, n_mels=n_filters, 
                                      fmin=fmin, fmax=fmax)
    
    # Apply filterbank
    S_filtered = np.dot(filterbank, S)
    
    # Log compression (add small epsilon for numerical stability)
    S_log = np.log(S_filtered + 1e-10)
    
    # DCT to get cepstral coefficients
    lfcc = dct(S_log, type=2, axis=0, norm='ortho')[:n_lfcc]
    
    return lfcc


def compute_delta(features, width=2):
    """
    Compute delta (first derivative) features.
    """
    n_frames = features.shape[1]
    if n_frames < 2 * width + 1:
        return np.zeros_like(features)
    
    delta = np.zeros_like(features)
    denominator = 2 * sum([i**2 for i in range(1, width + 1)])
    
    for t in range(n_frames):
        delta[:, t] = sum([
            i * (features[:, min(n_frames - 1, t + i)] - features[:, max(0, t - i)])
            for i in range(1, width + 1)
        ]) / denominator
    
    return delta


def analyze_lfcc_statistics(lfcc, delta_lfcc):
    """
    Analyze LFCC statistics to detect synthetic speech.
    
    Synthetic speech often has:
    - Lower variance in cepstral coefficients (too smooth)
    - Unnatural temporal dynamics
    - Regular patterns in delta features
    """
    results = {}
    
    # Mean and std of LFCC
    lfcc_mean = np.mean(lfcc, axis=1)
    lfcc_std = np.std(lfcc, axis=1)
    
    # Mean and std of delta LFCC
    delta_mean = np.mean(delta_lfcc, axis=1)
    delta_std = np.std(delta_lfcc, axis=1)
    
    # Key statistics for detection
    # Focus on lower-order coefficients (1-6) which capture spectral envelope
    results['lfcc_variance'] = np.mean(lfcc_std[1:6])
    results['delta_variance'] = np.mean(delta_std[1:6])
    
    # Smoothness measure: ratio of variance in adjacent frames
    frame_diff = np.diff(lfcc, axis=1)
    results['temporal_smoothness'] = np.mean(np.abs(frame_diff))
    
    # Energy distribution across coefficients
    results['energy_ratio'] = np.mean(lfcc_std[:5]) / (np.mean(lfcc_std[5:]) + 1e-10)
    
    return results


def detect_deepfake(audio_path):
    """
    Main deepfake detection function using LFCC + statistical analysis.
    
    Args:
        audio_path: Path to preprocessed audio file (mono, 16kHz WAV)
        
    Returns:
        is_fake: Boolean indicating if audio is likely AI-generated
        confidence: Confidence score (0.0 to 1.0)
        explanation: String explaining the decision
    """
    try:
        # Load audio
        y, sr = librosa.load(audio_path, sr=16000)
        
        if len(y) < sr * 0.5:  # Less than 0.5 seconds
            return False, 0.5, "Audio too short for reliable analysis"
        
        # Extract LFCC features
        lfcc = extract_lfcc(y, sr=sr)
        
        # Compute delta features
        delta_lfcc = compute_delta(lfcc)
        
        # Analyze statistics
        stats = analyze_lfcc_statistics(lfcc, delta_lfcc)
        
        # Decision logic based on statistics
        # These thresholds are tuned for demonstration
        # A production system would use a trained GMM or neural classifier
        
        score = 0.5  # Start neutral
        explanations = []
        
        # Check LFCC variance
        if stats['lfcc_variance'] < 0.25:
            score += 0.2
            explanations.append("LFCC variance unusually low (synthetic-like)")
        elif stats['lfcc_variance'] > 0.6:
            score -= 0.15
            explanations.append("LFCC variance consistent with natural speech")
        
        # Check temporal smoothness
        if stats['temporal_smoothness'] < 0.3:
            score += 0.15
            explanations.append("Temporal dynamics too smooth (vocoder artifact)")
        elif stats['temporal_smoothness'] > 0.5:
            score -= 0.1
            explanations.append("Natural temporal variations detected")
        
        # Check delta variance
        if stats['delta_variance'] < 0.15:
            score += 0.1
            explanations.append("Delta features show unnatural stability")
        
        # Check energy distribution
        if stats['energy_ratio'] > 3.0:
            score += 0.1
            explanations.append("Unusual spectral energy distribution")
        
        # Ensure score is in valid range
        score = max(0.0, min(1.0, score))
        
        # Determine result
        is_fake = score > 0.5
        confidence = score if is_fake else (1.0 - score)
        
        if not explanations:
            explanations.append("Analysis inconclusive")
        
        return is_fake, confidence, explanations
        
    except Exception as e:
        return False, 0.5, [f"Analysis error: {str(e)}"]


if __name__ == "__main__":
    import sys
    if len(sys.argv) > 1:
        is_fake, conf, expl = detect_deepfake(sys.argv[1])
        print(f"Deepfake: {'AI' if is_fake else 'Real'} ({conf:.2f})")
        for e in expl:
            print(f"  - {e}")

"""
Gender Detection from Voice
===========================
Uses a pretrained wav2vec2 gender classifier as primary detector,
with pitch-based (F0) fallback if the ML model is unavailable.

Primary: alefiury/wav2vec2-large-xlsr-53-gender-recognition-librispeech
Fallback: Median F0 pitch thresholds via librosa.yin
"""

import os
import sys
import numpy as np
import librosa

MODEL_ID = "alefiury/wav2vec2-large-xlsr-53-gender-recognition-librispeech"
CACHE_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "_model_cache")

_model = None
_feature_extractor = None
_model_load_error = None
_model_attempted = False


def _try_load_model(verbose=False):
    global _model, _feature_extractor, _model_load_error, _model_attempted
    if _model_attempted:
        return _model is not None
    _model_attempted = True

    try:
        import torch
        from transformers import AutoFeatureExtractor, AutoModelForAudioClassification

        if verbose:
            print(f"[gender] Loading pretrained model: {MODEL_ID}", file=sys.stderr)

        _feature_extractor = AutoFeatureExtractor.from_pretrained(
            MODEL_ID, cache_dir=CACHE_DIR
        )
        _model = AutoModelForAudioClassification.from_pretrained(
            MODEL_ID, cache_dir=CACHE_DIR
        )
        _model.eval()

        if verbose:
            print(f"[gender] Model loaded successfully. Labels: {_model.config.id2label}", file=sys.stderr)

        return True
    except Exception as e:
        _model_load_error = str(e)
        if verbose:
            print(f"[gender] ML model failed to load: {e}", file=sys.stderr)
        return False


def _infer_ml(audio_16k: np.ndarray, sr: int = 16000, verbose: bool = False):
    """Run pretrained gender classifier. Returns (label, confidence, explanation)."""
    import torch

    inputs = _feature_extractor(
        audio_16k, sampling_rate=sr, return_tensors="pt", padding=True
    )
    with torch.no_grad():
        logits = _model(**inputs).logits
    probs = torch.softmax(logits, dim=-1)[0]

    id2label = _model.config.id2label
    female_idx = None
    male_idx = None
    for idx, lbl in id2label.items():
        lbl_lower = str(lbl).lower()
        if "female" in lbl_lower:
            female_idx = int(idx)
        elif "male" in lbl_lower:
            male_idx = int(idx)

    if female_idx is not None and male_idx is not None:
        p_female = float(probs[female_idx])
        p_male = float(probs[male_idx])
    else:
        p_female = float(probs[0])
        p_male = float(probs[1])

    if verbose:
        print(f"[gender] ML scores: P(female)={p_female:.4f}, P(male)={p_male:.4f}", file=sys.stderr)

    if p_male > p_female:
        label = "Male"
        confidence = p_male
    else:
        label = "Female"
        confidence = p_female

    if confidence < 0.60:
        label = "Uncertain"
        confidence = max(confidence, 0.40)

    explanation = (
        f"Pretrained gender classifier: P(male)={p_male:.3f}, P(female)={p_female:.3f}. "
        f"Predicted {label} with {confidence:.1%} confidence."
    )
    return label, round(float(confidence), 3), explanation


def _infer_pitch(audio_16k: np.ndarray, sr: int = 16000, verbose: bool = False):
    """Pitch-based fallback gender detection using librosa.yin."""
    audio_trimmed, _ = librosa.effects.trim(audio_16k, top_db=25)
    if len(audio_trimmed) < sr * 0.5:
        audio_trimmed = audio_16k

    f0 = librosa.yin(
        audio_trimmed, fmin=50, fmax=400, sr=sr,
        frame_length=2048, hop_length=512
    )

    voiced_mask = (f0 > 50) & (f0 < 400) & np.isfinite(f0)
    voiced_f0 = f0[voiced_mask]
    n_voiced = len(voiced_f0)

    if verbose:
        print(f"[gender] Pitch fallback: {n_voiced} voiced frames out of {len(f0)}", file=sys.stderr)

    if n_voiced < 10:
        return "Uncertain", 0.35, f"Too few voiced frames ({n_voiced}) for reliable pitch-based gender detection."

    median_pitch = float(np.median(voiced_f0))
    mean_pitch = float(np.mean(voiced_f0))
    std_pitch = float(np.std(voiced_f0))

    if verbose:
        print(f"[gender] Pitch: median={median_pitch:.1f} Hz, mean={mean_pitch:.1f} Hz, std={std_pitch:.1f} Hz", file=sys.stderr)

    if median_pitch < 165:
        label = "Male"
        distance = max(0, 165 - median_pitch)
        confidence = min(0.90, 0.60 + distance / 200)
    elif median_pitch > 190:
        label = "Female"
        distance = max(0, median_pitch - 190)
        confidence = min(0.90, 0.60 + distance / 200)
    else:
        label = "Uncertain"
        confidence = 0.40

    voiced_ratio = n_voiced / max(len(f0), 1)
    if voiced_ratio < 0.3:
        confidence *= 0.85

    if std_pitch > 60:
        confidence *= 0.90

    confidence = round(float(np.clip(confidence, 0.0, 1.0)), 3)

    explanation = (
        f"Pitch-based detection (fallback): median F0={median_pitch:.1f} Hz, "
        f"{n_voiced} voiced frames. "
        f"Predicted {label} with {confidence:.1%} confidence."
    )
    return label, confidence, explanation


def detect_gender(audio_path: str = None, audio_array: np.ndarray = None,
                  sr: int = 16000, verbose: bool = False):
    """
    Detect speaker gender from audio.

    Provide either audio_path (file path) or audio_array (numpy array at given sr).

    Returns:
        (gender, confidence, explanation)
        gender: "Male", "Female", or "Uncertain" (never "Unknown")
        confidence: float 0.0 to 1.0
        explanation: str describing the detection
    """
    try:
        if audio_array is not None:
            y = audio_array.astype(np.float32)
        elif audio_path is not None:
            y, sr = librosa.load(audio_path, sr=16000)
        else:
            return "Uncertain", 0.0, "No audio input provided."

        if y.ndim > 1:
            y = np.mean(y, axis=1)

        y = y.astype(np.float32)
        mx = float(np.max(np.abs(y)))
        if mx > 0:
            y = y / mx

        duration = len(y) / sr
        if duration < 2.0:
            return "Uncertain", 0.30, f"Audio too short ({duration:.1f}s) for reliable gender detection."

        y_trimmed, _ = librosa.effects.trim(y, top_db=25)
        trimmed_duration = len(y_trimmed) / sr
        if trimmed_duration < 1.0:
            return "Uncertain", 0.30, "Audio contains mostly silence; insufficient speech for gender detection."

        ml_loaded = _try_load_model(verbose=verbose)

        if ml_loaded:
            try:
                ml_label, ml_conf, ml_expl = _infer_ml(y, sr=sr, verbose=verbose)

                pitch_label, pitch_conf, pitch_expl = _infer_pitch(y, sr=sr, verbose=verbose)

                if verbose:
                    print(f"[gender] ML: {ml_label} ({ml_conf:.3f}), Pitch: {pitch_label} ({pitch_conf:.3f})", file=sys.stderr)

                if ml_label == pitch_label:
                    final_label = ml_label
                    final_conf = 0.7 * ml_conf + 0.3 * pitch_conf
                    method = "ML + pitch agreement"
                elif ml_label == "Uncertain":
                    final_label = pitch_label if pitch_conf >= 0.60 else "Uncertain"
                    final_conf = pitch_conf * 0.85
                    method = "pitch (ML uncertain)"
                elif pitch_label == "Uncertain":
                    final_label = ml_label
                    final_conf = ml_conf * 0.90
                    method = "ML (pitch uncertain)"
                else:
                    final_label = ml_label if ml_conf > pitch_conf else pitch_label
                    final_conf = max(ml_conf, pitch_conf) * 0.70
                    method = "disagreement resolved by confidence"

                final_conf = round(float(np.clip(final_conf, 0.0, 1.0)), 3)

                explanation = (
                    f"Gender detected via {method}. "
                    f"ML model: {ml_label} ({ml_conf:.1%}), "
                    f"Pitch analysis: {pitch_label} ({pitch_conf:.1%}). "
                    f"Final: {final_label} ({final_conf:.1%})."
                )
                return final_label, final_conf, explanation

            except Exception as e:
                if verbose:
                    print(f"[gender] ML inference failed, using pitch fallback: {e}", file=sys.stderr)
                return _infer_pitch(y, sr=sr, verbose=verbose)
        else:
            if verbose:
                print(f"[gender] Using pitch-based fallback (ML unavailable: {_model_load_error})", file=sys.stderr)
            return _infer_pitch(y, sr=sr, verbose=verbose)

    except Exception as e:
        return "Uncertain", 0.0, f"Gender detection error: {e}"


if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser(description="Gender Detection")
    p.add_argument("--input", required=True, help="Audio file path")
    p.add_argument("--verbose", "-v", action="store_true")
    args = p.parse_args()

    gender, conf, expl = detect_gender(audio_path=args.input, verbose=args.verbose)
    print(f"Gender: {gender}")
    print(f"Confidence: {conf:.1%}")
    print(f"Explanation: {expl}")

