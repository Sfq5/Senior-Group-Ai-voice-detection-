"""
Audio Preprocessing Module
==========================
Handles conversion of audio/video files to mono 16kHz WAV format
using ffmpeg with imageio-ffmpeg fallback.
"""

import os
import subprocess
import sys
import shutil
import tempfile


def get_ffmpeg_path():
    """
    Find ffmpeg executable.
    First tries system ffmpeg, then falls back to imageio-ffmpeg.
    """
    # Try system ffmpeg first
    ffmpeg = shutil.which('ffmpeg')
    if ffmpeg:
        return ffmpeg
    
    # Fallback to imageio-ffmpeg
    try:
        import imageio_ffmpeg
        ffmpeg = imageio_ffmpeg.get_ffmpeg_exe()
        if ffmpeg and os.path.exists(ffmpeg):
            return ffmpeg
    except ImportError:
        pass
    
    return None


def is_video_file(file_path):
    """Check if file is a video format."""
    video_extensions = ['.mp4', '.mov', '.mkv', '.webm', '.avi', '.wmv', '.flv']
    ext = os.path.splitext(file_path)[1].lower()
    return ext in video_extensions


def convert_to_wav(input_path, output_path=None, sample_rate=16000):
    """
    Convert audio/video file to mono 16kHz WAV.
    
    Args:
        input_path: Path to input audio/video file
        output_path: Optional output path. If None, creates temp file.
        sample_rate: Target sample rate (default 16000)
        
    Returns:
        Path to the converted WAV file
        
    Raises:
        FileNotFoundError: If input file doesn't exist
        RuntimeError: If conversion fails
    """
    if not os.path.exists(input_path):
        raise FileNotFoundError(f"Input file not found: {input_path}")
    
    # Get ffmpeg path
    ffmpeg_exe = get_ffmpeg_path()
    if not ffmpeg_exe:
        raise RuntimeError(
            "ffmpeg not found. Install ffmpeg or run: pip install imageio-ffmpeg"
        )
    
    # Determine output path
    if output_path is None:
        # Create temp file
        fd, output_path = tempfile.mkstemp(suffix='.wav')
        os.close(fd)
    
    # Build ffmpeg command
    cmd = [
        ffmpeg_exe,
        '-y',                    # Overwrite output
        '-i', input_path,        # Input file
        '-vn',                   # No video (extract audio only)
        '-acodec', 'pcm_s16le',  # 16-bit PCM
        '-ac', '1',              # Mono
        '-ar', str(sample_rate), # Sample rate
        '-f', 'wav',             # Output format
        output_path
    ]
    
    try:
        # Run ffmpeg with suppressed output
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=True
        )
        return output_path
        
    except subprocess.CalledProcessError as e:
        error_msg = e.stderr.decode() if e.stderr else str(e)
        # Clean up failed output
        if os.path.exists(output_path):
            os.remove(output_path)
        raise RuntimeError(f"ffmpeg conversion failed: {error_msg}")


def get_audio_info(file_path):
    """
    Get basic audio information using ffprobe.
    
    Returns:
        dict with duration, sample_rate, channels, codec
    """
    ffprobe = shutil.which('ffprobe')
    if not ffprobe:
        # Try imageio-ffmpeg path
        try:
            import imageio_ffmpeg
            ffmpeg_path = imageio_ffmpeg.get_ffmpeg_exe()
            ffprobe = os.path.join(os.path.dirname(ffmpeg_path), 'ffprobe')
            if not os.path.exists(ffprobe):
                ffprobe = None
        except:
            ffprobe = None
    
    if not ffprobe:
        return None
    
    cmd = [
        ffprobe,
        '-v', 'quiet',
        '-print_format', 'json',
        '-show_format',
        '-show_streams',
        file_path
    ]
    
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        import json
        data = json.loads(result.stdout)
        
        info = {
            'duration': 0,
            'sample_rate': 0,
            'channels': 0,
            'codec': 'unknown'
        }
        
        # Get duration from format
        if 'format' in data and 'duration' in data['format']:
            info['duration'] = float(data['format']['duration'])
        
        # Get audio stream info
        for stream in data.get('streams', []):
            if stream.get('codec_type') == 'audio':
                info['sample_rate'] = int(stream.get('sample_rate', 0))
                info['channels'] = int(stream.get('channels', 0))
                info['codec'] = stream.get('codec_name', 'unknown')
                break
        
        return info
        
    except Exception as e:
        return None


