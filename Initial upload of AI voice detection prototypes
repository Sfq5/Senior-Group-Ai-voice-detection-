            "best_for": ["Cross-dataset generalization", "In-the-wild detection"],
            "cpu_speed": "Very Slow",
            "reference": "Tak et al., Odyssey 2022"
        }
    }
    
    key = name.lower().replace(" ", "_").replace("-", "_")
    if "aasist" in key:
