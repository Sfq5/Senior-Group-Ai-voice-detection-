"""
Audio Metadata Extraction Module
================================
Extracts duration, sample rate, channels, and other metadata from audio/video files.
"""

import subprocess
import json
import shutil
import os


def get_ffprobe_path():
    """Find ffprobe executable."""
    ffprobe = shutil.which('ffprobe')
    if ffprobe:
        return ffprobe
    
    # Try imageio-ffmpeg path
    try:
        import imageio_ffmpeg
        ffmpeg_path = imageio_ffmpeg.get_ffmpeg_exe()
        ffprobe = os.path.join(os.path.dirname(ffmpeg_path), 'ffprobe')
        if os.path.exists(ffprobe):
            return ffprobe
    except:
        pass
    
    return None


def get_metadata(file_path):
    """
    Get audio/video metadata using ffprobe.
    
    Args:
        file_path: Path to audio/video file
        
    Returns:
        dict with:
            - duration: Duration in seconds
            - sample_rate: Sample rate as string (e.g., "44100Hz")
            - channels: "mono" or "stereo"
            - codec: Audio codec name
            - bitrate: Bitrate if available
    """
    result = {
        "duration": 0,
        "sample_rate": "Unknown",
        "channels": "Unknown",
        "codec": "Unknown",
        "bitrate": "Unknown"
    }
    
    ffprobe_exe = get_ffprobe_path()
    if not ffprobe_exe:
        # Fallback: try to get duration using librosa
        try:
            import librosa
            y, sr = librosa.load(file_path, sr=None, duration=None)
            result["duration"] = len(y) / sr
            result["sample_rate"] = f"{sr}Hz"
            result["channels"] = "mono"  # librosa loads as mono by default
            return result
        except:
            return result
    
    cmd = [
        ffprobe_exe,
        '-v', 'quiet',
        '-print_format', 'json',
        '-show_format',
        '-show_streams',
        file_path
    ]
    
    try:
        proc = subprocess.run(
            cmd, 
            stdout=subprocess.PIPE, 
            stderr=subprocess.PIPE, 
            text=True
        )
        data = json.loads(proc.stdout)
        
        # Get duration from format
        if 'format' in data:
            fmt = data['format']
            if 'duration' in fmt:
                result['duration'] = float(fmt['duration'])
            if 'bit_rate' in fmt:
                bitrate = int(fmt['bit_rate']) // 1000
                result['bitrate'] = f"{bitrate}kbps"
        
        # Get audio stream info
        for stream in data.get('streams', []):
            if stream.get('codec_type') == 'audio':
                # Sample rate
                if 'sample_rate' in stream:
                    sr = int(stream['sample_rate'])
                    result['sample_rate'] = f"{sr}Hz"
                
                # Channels
                if 'channels' in stream:
                    ch = int(stream['channels'])
                    result['channels'] = "mono" if ch == 1 else "stereo" if ch == 2 else f"{ch}ch"
                
                # Codec
                if 'codec_name' in stream:
                    result['codec'] = stream['codec_name']
                
                # Duration fallback
                if result['duration'] == 0 and 'duration' in stream:
                    result['duration'] = float(stream['duration'])
                
                break
        
        return result
        
    except Exception as e:
        return result


def format_duration(seconds):
    """Format duration in seconds to human-readable string."""
    if seconds < 60:
        return f"{seconds:.1f}s"
    elif seconds < 3600:
        mins = int(seconds // 60)
        secs = seconds % 60
        return f"{mins}m {secs:.0f}s"
    else:
        hours = int(seconds // 3600)
        mins = int((seconds % 3600) // 60)
        return f"{hours}h {mins}m"


